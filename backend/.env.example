# Server Configurations
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Database URI
MONGO_URI=mongodb://localhost:27017/foxnut

# JWT Secrets
ACCESS_TOKEN_SECRET=your_jwt_access_token_secret_string_32_chars_plus
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_jwt_refresh_token_secret_string_32_chars_plus
REFRESH_TOKEN_EXPIRY=10d

# Cloudinary Details
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay Credentials
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# SMTP Email Services (Mailtrap or standard provider)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_user_id
EMAIL_PASS=your_smtp_password
EMAIL_FROM=no-reply@bharatharvest.com
